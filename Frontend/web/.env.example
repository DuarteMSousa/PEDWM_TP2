# Docker backend (compose): http://127.0.0.1
# php artisan serve: http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1

VITE_REVERB_APP_KEY=fastbite-key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Dev-only fallback for private channel auth (local/testing backend only)
VITE_DEV_BROADCAST_USER_ID=
VITE_DEV_RESTAURANT_USER_ID=
VITE_DEV_RESTAURANT_ID=

# Optional: bearer token if /broadcasting/auth is protected by token auth
VITE_AUTH_BEARER_TOKEN=

# Optional defaults for realtime UI panels
VITE_REALTIME_CHAT_ID=
VITE_REALTIME_USER_ID=
