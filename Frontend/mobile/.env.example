# Docker backend (compose): http://127.0.0.1
# php artisan serve: http://127.0.0.1:8000
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1

EXPO_PUBLIC_REVERB_APP_KEY=fastbite-key
EXPO_PUBLIC_REVERB_HOST=127.0.0.1
EXPO_PUBLIC_REVERB_PORT=8080
EXPO_PUBLIC_REVERB_SCHEME=http

# Use a valid order UUID from the backend
EXPO_PUBLIC_TRACKING_ORDER_ID=

# Dev-only fallback for private channel auth (local/testing backend only)
EXPO_PUBLIC_DEV_BROADCAST_USER_ID=

# Optional: bearer token if /broadcasting/auth is protected by token auth
EXPO_PUBLIC_AUTH_BEARER_TOKEN=

# Optional defaults for realtime UI panels
EXPO_PUBLIC_REALTIME_CHAT_ID=
EXPO_PUBLIC_REALTIME_USER_ID=
