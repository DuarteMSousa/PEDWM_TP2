@startuml
title FastBite MVP - Arquitetura Logica
skinparam componentStyle rectangle
left to right direction

actor Customer
actor "Restaurant Staff" as Staff
actor Courier

package "Frontend" {
  component "Web App\n(React)" as Web
  component "Mobile App\n(React Native)" as Mobile
}

package "Backend Laravel" {
  component "GraphQL API\n(Lighthouse)" as API
  component "Auth + Roles" as Auth
  component "Order Service" as OrderSvc
  component "Payment Service" as PaySvc
  component "Delivery Service" as DeliverySvc
  component "Notification Service" as NotifSvc
  component "Outbox Worker\n(Queue Jobs)" as Outbox
}

package "Realtime" {
  component "Reverb\n(WebSocket Broker)" as Reverb
}

database "MySQL/PostgreSQL" as DB

Customer --> Web
Customer --> Mobile
Staff --> Web
Courier --> Mobile

Web --> API : Query/Mutation
Mobile --> API : Query/Mutation

API --> Auth
API --> OrderSvc
API --> PaySvc
API --> DeliverySvc
API --> NotifSvc

OrderSvc --> DB
PaySvc --> DB
DeliverySvc --> DB
NotifSvc --> DB
Outbox --> DB

OrderSvc --> Outbox : write events
PaySvc --> Outbox : write events
DeliverySvc --> Outbox : write events

Outbox --> Reverb : publish domain events
Web <-- Reverb : subscriptions
Mobile <-- Reverb : subscriptions

@enduml
