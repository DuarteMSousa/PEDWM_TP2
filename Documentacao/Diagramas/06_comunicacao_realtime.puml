@startuml FastBite_Realtime
title FastBite — Arquitetura Event-Driven / Comunicacao em Tempo Real

skinparam shadowing false
skinparam component {
  BackgroundColor #FAFAFA
  BorderColor #555
  ArrowColor #555
}

' =======================
' ENUM DE EVENTOS
' =======================

package "Tipos de Eventos (Backend/app/Enums)" as Enums {
  card "OrderEventType\n----\nORDER_CREATED\nORDER_PAYMENT_COMPLETED\nORDER_CONFIRMED\nORDER_PREPARING\nORDER_READY\nORDER_PICKED_UP\nORDER_OUT_FOR_DELIVERY\nORDER_DELIVERED\nORDER_CANCELLED\nORDER_COURIER_ASSIGNED\nORDER_REJECTED" as EnumOrder
  card "PaymentEventType\n----\nPAYMENT_CREATED\nPAYMENT_COMPLETED\nPAYMENT_FAILED\nPAYMENT_EXPIRED\nPAYMENT_CANCELLED" as EnumPayment
  card "DeliveryEventType\n----\nDELIVERY_ACCEPTED\nDELIVERY_PICKED_UP\nDELIVERY_IN_TRANSIT\nDELIVERY_DELIVERED\nDELIVERY_FAILED" as EnumDelivery
  card "DeliveryOfferEventType\n----\nJOB_OFFERED\nJOB_ACCEPTED\nJOB_REJECTED\nJOB_EXPIRED" as EnumOffer
}

' =======================
' BACKEND
' =======================

package "Backend (Laravel)" as BE {
  component "OrderService\n<<Transactional>>" as OrderSvc
  component "DeliveryService" as DeliverySvc
  component "PaymentService" as PaymentSvc
  database "order_events\npayment_events\ndelivery_events" as EventsTable
  database "outbox_events" as Outbox
  component "OutboxEventWorker\n(queue:work)" as Worker
  component "Reverb\nWebSocket Server" as Reverb
  component "DomainEventBroadcasted\n(ShouldBroadcast)" as DEB
}

OrderSvc -down-> EventsTable : persist event\n(audit / event sourcing)
DeliverySvc -down-> EventsTable : persist event
PaymentSvc -down-> EventsTable : persist event

OrderSvc -down-> Outbox : enqueue('order', id, type, payload)
DeliverySvc -down-> Outbox : enqueue('delivery', id, type, payload)
PaymentSvc -down-> Outbox : enqueue('payment', id, type, payload)

Worker -up-> Outbox : SELECT status=PENDING\nORDER BY next_attempt_at
Worker -right-> DEB : dispatch
DEB -down-> Reverb : broadcast(channels)

note left of Outbox #LightYellow
  Outbox Pattern:
  garante que evento e
  publicacao sao
  atomicos (mesma TX).
end note

' =======================
' CANAIS REVERB
' =======================

package "Canais Reverb" as Channels {
  rectangle "customer.{userId}.orders" as ChCustomer
  rectangle "restaurant.{restaurantId}.orders" as ChRest
  rectangle "order.{orderId}.tracking" as ChTrack
  rectangle "courier.{courierId}.jobs" as ChJobs
  rectangle "user.{userId}.notifications" as ChNotif
  rectangle "chat.{chatId}" as ChChat
}

Reverb --> ChCustomer
Reverb --> ChRest
Reverb --> ChTrack
Reverb --> ChJobs
Reverb --> ChNotif
Reverb --> ChChat

' =======================
' CLIENTES
' =======================

package "Frontend Web (React)" as Web {
  component "Apollo / GraphQL\n(Lighthouse Client)" as ApolloW
  component "Laravel Echo\n+ pusher-js" as EchoW
  component "RestaurantOrdersQueue\nRestaurantOrderDetail\nRestaurantChat" as RestUI
  component "CustomerTracking" as CustomerUI
}

package "Frontend Mobile (React Native)" as Mobile {
  component "GraphQL Client\n(fetch wrapper)" as ApolloM
  component "Laravel Echo\n+ pusher-js" as EchoM
  component "CustomerAppScreen" as CustApp
  component "CourierAppScreen\n(JOB_OFFERED listener)" as CourierApp
}

ChRest --> EchoW : subscribe
ChCustomer --> EchoM : subscribe
ChTrack --> EchoM : subscribe
ChTrack --> EchoW : subscribe (tracking web)
ChJobs --> EchoM : subscribe (courier)
ChNotif --> EchoW
ChNotif --> EchoM
ChChat --> EchoW
ChChat --> EchoM

EchoW --> RestUI
EchoW --> CustomerUI
EchoM --> CustApp
EchoM --> CourierApp

ApolloW -.-> BE : queries / mutations\n(HTTP GraphQL)
ApolloM -.-> BE : queries / mutations\n(HTTP GraphQL)

note right of Worker #LightCyan
  Padrao Observer aplicado:
  o EventBus desacopla
  produtor (Service) de
  consumidor (Reverb).
  Permite adicionar novos
  observadores (push, email,
  analytics) sem alterar a
  logica de negocio.
end note

@enduml
